---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Lookbook', href: '#lookbook' },
  { label: 'Tim', href: '#barbers' },
  { label: 'Lokasi', href: '#locations' },
  { label: 'Membership', href: '#membership' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50"
  style="background-color: rgba(13,13,13,0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid #2a2a2a;"
>
  <nav
    class="flex items-center justify-between"
    style="max-width: 1440px; margin: 0 auto; padding: 0 40px; height: 64px;"
  >
    <!-- Logo -->
    <a
      href="/"
      style="font-family: var(--font-display); font-size: 24px; color: var(--color-canvas); letter-spacing: 0.08em; text-decoration: none; white-space: nowrap;"
      aria-label="The Cutroom Home"
    >
      THE CUTROOM
    </a>

    <!-- Desktop Nav Links -->
    <ul
      class="hidden md:flex items-center"
      style="gap: 36px; list-style: none;"
    >
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            style="font-family: var(--font-body); font-size: 14px; font-weight: 500; color: var(--color-stone); text-decoration: none; letter-spacing: 0.03em; transition: color 0.2s;"
            class="nav-link"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex items-center" style="gap: 16px;">
      <a
        href="#book"
        style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          height: 40px;
          padding: 0 24px;
          background-color: var(--color-canvas);
          color: var(--color-ink);
          font-family: var(--font-body);
          font-size: 14px;
          font-weight: 500;
          letter-spacing: 0.05em;
          text-decoration: none;
          border-radius: 30px;
          transition: background-color 0.2s, color 0.2s;
          white-space: nowrap;
        "
        class="btn-book"
      >
        Book Now
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="hamburger"
        class="flex md:hidden flex-col justify-center items-center"
        style="width: 40px; height: 40px; background: none; border: none; cursor: pointer; gap: 5px;"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="hamburger-line" style="display: block; width: 22px; height: 2px; background-color: var(--color-canvas); transition: transform 0.3s;"></span>
        <span class="hamburger-line" style="display: block; width: 22px; height: 2px; background-color: var(--color-canvas); transition: opacity 0.3s;"></span>
        <span class="hamburger-line" style="display: block; width: 22px; height: 2px; background-color: var(--color-canvas); transition: transform 0.3s;"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    style="
      display: none;
      padding: 16px 40px 24px;
      border-top: 1px solid #2a2a2a;
    "
  >
    <ul style="list-style: none; display: flex; flex-direction: column; gap: 4px;">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            style="
              display: block;
              padding: 12px 0;
              font-family: var(--font-body);
              font-size: 16px;
              font-weight: 500;
              color: var(--color-stone);
              text-decoration: none;
              letter-spacing: 0.03em;
              border-bottom: 1px solid #1e1e1e;
              transition: color 0.2s;
            "
            class="mobile-nav-link"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li style="padding-top: 16px;">
        <a
          href="#book"
          style="
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 44px;
            padding: 0 28px;
            background-color: var(--color-canvas);
            color: var(--color-ink);
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-decoration: none;
            border-radius: 30px;
          "
        >
          Book Now
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav-link:hover {
    color: var(--color-canvas) !important;
  }
  .mobile-nav-link:hover {
    color: var(--color-canvas) !important;
  }
  .btn-book:hover {
    background-color: var(--color-soft-cloud) !important;
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll('.hamburger-line');

  let isOpen = false;

  hamburger?.addEventListener('click', () => {
    isOpen = !isOpen;
    hamburger.setAttribute('aria-expanded', String(isOpen));

    if (mobileMenu) {
      mobileMenu.style.display = isOpen ? 'block' : 'none';
    }

    if (lines[0] && lines[1] && lines[2]) {
      if (isOpen) {
        (lines[0] as HTMLElement).style.transform = 'translateY(7px) rotate(45deg)';
        (lines[1] as HTMLElement).style.opacity = '0';
        (lines[2] as HTMLElement).style.transform = 'translateY(-7px) rotate(-45deg)';
      } else {
        (lines[0] as HTMLElement).style.transform = '';
        (lines[1] as HTMLElement).style.opacity = '1';
        (lines[2] as HTMLElement).style.transform = '';
      }
    }
  });

  // Close menu when nav link is clicked
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      isOpen = false;
      if (mobileMenu) mobileMenu.style.display = 'none';
      hamburger?.setAttribute('aria-expanded', 'false');
      if (lines[0] && lines[1] && lines[2]) {
        (lines[0] as HTMLElement).style.transform = '';
        (lines[1] as HTMLElement).style.opacity = '1';
        (lines[2] as HTMLElement).style.transform = '';
      }
    });
  });
</script>
